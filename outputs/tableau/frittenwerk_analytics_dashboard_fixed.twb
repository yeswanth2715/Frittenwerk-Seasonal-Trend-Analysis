            <column aggregation="Sum" datatype="real" name="[Value]" role="measure" type="quantitative" />
            <column-instance column="[Chart Section]" derivation="None" name="[none:Chart Section:nk]" pivot="key" type="nominal" />
            <column-instance column="[Category]" derivation="None" name="[none:Category:nk]" pivot="key" type="nominal" />
            <column-instance column="[Category]" derivation="Attribute" name="[attr:Category:nk]" pivot="key" type="nominal" />
            <column-instance column="[Value]" derivation="Sum" name="[sum:Value:qk]" pivot="key" type="quantitative" />
          </datasource-dependencies>
          <filter class="categorical" column="[DashboardData].[Chart Section]">
            <groupfilter function="member" level="[Chart Section]" member="&quot;Inventory Wastage Drivers&quot;" user:ui-domain="database" user:ui-enumeration="inclusive" user:ui-marker="enumerate" />
          </filter>
          <slices>
            <column>[DashboardData].[Category]</column>
            <column>[DashboardData].[sum:Value:qk]</column>
          </slices>
          <aggregation value="true" />
        </view>
        <style>
          <style-rule element="axis">
            <format attr="title" class="0" field="[DashboardData].[sum:Value:qk]" scope="cols" value="Estimated Waste Units" />
            <format attr="auto-subtitle" class="0" field="[DashboardData].[sum:Value:qk]" scope="cols" value="true" />
          </style-rule>
          <style-rule element="worksheet">
            <format attr="display-field-labels" scope="rows" value="false" />
            <format attr="color" value="#1F2937" />
          </style-rule>
          <style-rule element="label">
            <format attr="color" field="[DashboardData].[sum:Value:qk]" value="#1F2937" />
            <format attr="font-size" field="[DashboardData].[sum:Value:qk]" value="9" />
          </style-rule>
          <style-rule element="cell">
            <format attr="text-format" field="[DashboardData].[sum:Value:qk]" value="*#,##0" />
          </style-rule>
          <style-rule element="tooltip">
            <format attr="font-size" value="11" />
            <format attr="color" value="#334155" />
          </style-rule>
        </style>
        <panes>
          <pane>
            <view>
              <breakdown value="auto" />
            </view>
            <mark class="Circle" />
            <encodings>
              <color column="[DashboardData].[Category]" />
              <size column="[DashboardData].[sum:Value:qk]" />
              <text column="[DashboardData].[sum:Value:qk]" />
              <tooltip column="[DashboardData].[attr:Category:nk]" />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run fontcolor="#64748B">Category:	</run>
                <run bold="true">&lt;[DashboardData].[attr:Category:nk]&gt;
</run>
                <run fontcolor="#64748B">Value:	</run>
                <run bold="true">&lt;[DashboardData].[sum:Value:qk]&gt;</run>
              </formatted-text>
            </customized-tooltip>
            <style>
              <style-rule element="datalabel">
                <format attr="font-size" value="9" />
                <format attr="font-family" value="Arial" />
                <format attr="color" value="#111827" />
              </style-rule>
              <style-rule element="mark">
                <format attr="mark-labels-show" value="true" />
                <format attr="mark-labels-cull" value="true" />
                <format attr="has-stroke" value="true" />
                <format attr="stroke-color" value="#E5E7EB" />
                <format attr="stroke-size" value="1" />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[DashboardData].[Category]</rows>
        <cols>[DashboardData].[sum:Value:qk]</cols>
      </table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name="Frittenwerk Analytics Overview">
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor="#111827" fontname="Arial" fontsize="17">Frittenwerk Analytics Overview</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element="dash-text">
          <format attr="wrap" id="dash-text_intro" value="on" />
        </style-rule>
      </style>
      <size maxheight="920" maxwidth="1280" minheight="920" minwidth="1280" />
      <datasources>
        <datasource caption="Frittenwerk Dashboard Data" name="DashboardData" />
      </datasources>
      <zones>
        <zone h="100000" id="1" type="layout-basic" w="100000" x="0" y="0">
          <zone h="5000" id="2" type="title" w="100000" x="0" y="0" />
          <zone h="4200" id="3" type="text" w="100000" x="0" y="5600">
            <formatted-text>
              <run fontcolor="#475569" fontsize="10">Restaurant performance snapshot across </run>
              <run bold="true" fontcolor="#0F766E" fontsize="10">sales</run>
              <run fontcolor="#475569" fontsize="10">, </run>
              <run bold="true" fontcolor="#D97706" fontsize="10">seasonality</run>
              <run fontcolor="#475569" fontsize="10">, </run>
              <run bold="true" fontcolor="#DB2777" fontsize="10">festival demand</run>
              <run fontcolor="#475569" fontsize="10">, and </run>
              <run bold="true" fontcolor="#2563EB" fontsize="10">inventory risk</run>
              <run fontcolor="#475569" fontsize="10"> for the 2024-01 to 2026-03 portfolio window.</run>
            </formatted-text>
          </zone>
          <zone h="9500" id="4" param="horz" type="layout-flow" w="100000" x="0" y="11200">
            <zone h="9500" id="5" type="text" w="24500" x="0" y="11200" fixed-size="280" is-fixed="true">
              <formatted-text>
                <run bold="true" fontcolor="#64748B" fontsize="10">Total Sales
</run>
                <run bold="true" fontcolor="#0F766E" fontsize="20">4,564,797
</run>
                <run fontcolor="#334155" fontsize="9">Avg order value 19.10</run>
              </formatted-text>
            </zone>
            <zone h="9500" id="6" type="text" w="25500" x="24500" y="11200" fixed-size="280" is-fixed="true">
              <formatted-text>
                <run bold="true" fontcolor="#64748B" fontsize="10">Total Orders
</run>
                <run bold="true" fontcolor="#B45309" fontsize="20">238,789
</run>
                <run fontcolor="#334155" fontsize="9">Top promo Karneval Combo</run>
              </formatted-text>
            </zone>
            <zone h="9500" id="7" type="text" w="25000" x="50000" y="11200" fixed-size="280" is-fixed="true">
              <formatted-text>
                <run bold="true" fontcolor="#64748B" fontsize="10">Peak Month
</run>
                <run bold="true" fontcolor="#DB2777" fontsize="20">Dec
</run>
                <run fontcolor="#334155" fontsize="9">203,931 sales | seasonality peak Dec</run>
              </formatted-text>
            </zone>
            <zone h="9500" id="8" type="text" w="25000" x="75000" y="11200" fixed-size="280" is-fixed="true">
              <formatted-text>
                <run bold="true" fontcolor="#64748B" fontsize="10">Wastage Rate
</run>
                <run bold="true" fontcolor="#2563EB" fontsize="20">4.8%
</run>
                <run fontcolor="#334155" fontsize="9">Top festival Easter Weekend | driver Festival stock uplift</run>
              </formatted-text>
            </zone>
          </zone>
          <zone h="30500" id="9" name="Monthly Sales Trend" show-title="true" w="50000" x="0" y="24500" />
          <zone h="30500" id="10" name="Seasonality Wave" show-title="true" w="50000" x="50000" y="24500" />
          <zone h="27000" id="11" name="Festival Demand Lift" show-title="true" w="50000" x="0" y="58500" />
          <zone h="27000" id="12" name="Inventory Risk Bubbles" show-title="true" w="50000" x="50000" y="58500" />
          <zone h="4000" id="13" type="text" w="100000" x="0" y="89500">
            <formatted-text>
              <run fontcolor="#64748B" fontsize="9">Chart mix: </run>
              <run bold="true" fontcolor="#0F766E" fontsize="9">trend line</run>
              <run fontcolor="#64748B" fontsize="9"> for sales, </run>
              <run bold="true" fontcolor="#D97706" fontsize="9">filled area</run>
              <run fontcolor="#64748B" fontsize="9"> for seasonality, </run>
              <run bold="true" fontcolor="#DB2777" fontsize="9">ranked bars</run>
              <run fontcolor="#64748B" fontsize="9"> for demand lift, and </run>
              <run bold="true" fontcolor="#2563EB" fontsize="9">bubble marks</run>
              <run fontcolor="#64748B" fontsize="9"> for wastage drivers.</run>
            </formatted-text>
          </zone>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
